<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/act_validation_stone_code_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Digite o Stone Code" />

    <EditText
        android:id="@+id/act_validation_stone_code_edt_txt"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/act_validation_stone_code_txt"
        android:layout_centerHorizontal="true"
        android:gravity="center"
        android:inputType="number" />

    <Button
        android:id="@+id/act_validation_activate_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/act_validation_stone_code_edt_txt"
        android:layout_centerHorizontal="true"
        android:text="Ativar" />
</RelativeLayout>

